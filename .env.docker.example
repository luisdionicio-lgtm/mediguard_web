# Copia este archivo a .env.docker y ajusta los valores si lo necesitas.
# Estos son valores de EJEMPLO para desarrollo local — no son secretos reales
# y no deben usarse en producción.

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=mediguard_db
POSTGRES_USER=mediguard_user
POSTGRES_PASSWORD=mediguard_password_dev

# ── JWT compartido entre Django y Spring Boot ────────────────────────────
# Debe tener al menos 32 caracteres. Si no coincide entre ambos backends,
# los tokens emitidos por uno no serán válidos para el otro.
JWT_SECRET=mediguard-local-dev-secret-key-2026-minimo-32-chars

# ── Django ────────────────────────────────────────────────────────────────
# SECRET_KEY es obligatorio para Django (no tiene valor por defecto).
SECRET_KEY=django-insecure-dev-only-change-me-1234567890
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend_django

# ── Frontend (usado por CORS en Django) ──────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Google OAuth (login social) ───────────────────────────────────────────
# Opcionales — deja vacío si no vas a probar Google Login en Docker.
# VITE_GOOGLE_CLIENT_ID: usado por el frontend (React). Es el Client ID
# público que Google entrega para el flujo implícito; NO es secreto.
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET: usados por Spring Boot
# (usuario/src/main/resources/application.properties). El Client Secret
# nunca debe ir al frontend ni exponerse en React.
# No pongas valores reales en este archivo de ejemplo; cópialos a tu
# .env.docker local (ignorado por Git).
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
